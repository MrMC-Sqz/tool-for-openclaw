PROJECT_NAME=OpenClaw Skill Explorer + Risk Scanner
APP_NAME=OpenClaw Skill Explorer + Risk Scanner API
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
DATABASE_URL=sqlite:///./openclaw_skill_explorer.db
DATABASE_URL_POSTGRES_EXAMPLE=postgresql+psycopg://openclaw:openclaw@localhost:5432/openclaw_skill_explorer
DB_POOL_PRE_PING=true
CACHE_ENABLED=true
CACHE_TTL_SECONDS=30
AUTH_ENABLED=false
AUTH_API_KEYS=admin:change-me-admin,reviewer:change-me-reviewer,viewer:change-me-viewer
GITHUB_TOKEN=
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-5.4-mini
OPENAI_FALLBACK_MODEL=gpt-5.3
OPENAI_TIMEOUT_SECONDS=15
CORS_ALLOW_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
POSTGRES_DB=openclaw_skill_explorer
POSTGRES_USER=openclaw
POSTGRES_PASSWORD=openclaw
